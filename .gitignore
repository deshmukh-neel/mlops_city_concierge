# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class
.DS_Store

# C extensions
*.so

# Data
*.json

# Auto-generated per-run eval reports (Plan 03-05 / EVAL-05). Each
# `make eval-matrix` invocation writes eval_reports/{ISO8601-Z}/... with
# one JSON per (provider, model, scenario, run) cell + a summary.json.
# These are local-only — committed baselines live elsewhere (see below).
eval_reports/

# Committed eval baselines (Plan 03-07 / EVAL-07). The blanket `*.json`
# rule above would catch these too, so explicitly re-include them. Plan
# 03-07 commits the per-scenario baseline JSONs that Phase 4-6 merge gates
# diff against. Phase 6 plan 06-07 added a `_snapshots/` subdirectory for
# pre-regen baseline snapshots (reference-only; see _snapshots/README.md)
# — also re-included so the snapshots can be committed to the repo.
!configs/eval_baselines/
!configs/eval_baselines/*.json
!configs/eval_baselines/_snapshots/
!configs/eval_baselines/_snapshots/*.json

# Committed frozen paraphrases for the loop falsifier gate (Phase 16 Plan 03 / FALSIFY-01).
# The blanket *.json rule above would catch this, so explicitly re-include it.
# This file must be committed — it is the frozen, non-regenerating paraphrase set (D-06).
!configs/falsifier_paraphrases.json

# Committed test fixtures (Phase 8 Plan 05 / REASON-06 / D-08-15). The
# REASON-06 byte-identity regression baseline lives at
# tests/unit/fixtures/reason_04_prune_baseline.json — it MUST be committed
# alongside the test so it cannot drift silently. Re-include the entire
# tests/unit/fixtures/ directory so future fixture additions don't need a
# parallel .gitignore edit.
!tests/unit/fixtures/
!tests/unit/fixtures/*.json

