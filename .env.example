# ─────────────────────────────────────────────
# City Concierge — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Never commit the actual .env file.
# ─────────────────────────────────────────────

# ── PostgreSQL / pgvector ─────────────────────
POSTGRES_DB=city_concierge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Option A: use a full connection string directly.
# Local Docker example:
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/city_concierge

# Option B: build the connection string from POSTGRES_*.
# For Cloud SQL over Unix sockets, leave DATABASE_URL empty and set:
# CLOUD_SQL_INSTANCE_CONNECTION_NAME=your-project:your-region:your-instance
# CLOUD_SQL_SOCKET_DIR=/cloudsql
# Optional for direct host connections:
# POSTGRES_SSLMODE=require
# POSTGRES_SSLROOTCERT=/path/to/server-ca.pem

# ── OpenAI (embeddings + LLM) ─────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── Gemini (optional LLM provider) ────────────
GEMINI_API_KEY=AIza...
GEMINI_CHAT_MODEL=gemini-2.5-flash

# ── MLflow ────────────────────────────────────
MLFLOW_TRACKING_URI=http://35.223.147.177:5000
MLFLOW_ARTIFACTS_URI=mlflow-artifacts://35.223.147.177:5000
MLFLOW_MODEL_NAME=city-concierge-rag

# ── Application ───────────────────────────────
APP_PORT=8000
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO
RETRIEVER_K=5

# ── Ingestion ─────────────────────────────────
# Local path or remote URL used by the ingest pipeline
DATA_SOURCE_PATH=./data/cities.jsonl
