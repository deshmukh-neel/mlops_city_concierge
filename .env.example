# ─────────────────────────────────────────────
# City Concierge — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Never commit the actual .env file.
# ─────────────────────────────────────────────

# ── PostgreSQL / pgvector ─────────────────────
POSTGRES_DB=city_concierge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Constructed by docker-compose from the above; set manually for local dev without Docker
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/city_concierge

# ── OpenAI (embeddings + LLM) ─────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── Gemini (optional LLM provider) ────────────
GEMINI_API_KEY=AIza...
GEMINI_CHAT_MODEL=gemini-2.5-flash

# ── MLflow ────────────────────────────────────
MLFLOW_TRACKING_URI=http://35.223.147.177:5000
MLFLOW_ARTIFACTS_URI=mlflow-artifacts://35.223.147.177:5000
MLFLOW_MODEL_NAME=city-concierge-rag

# ── Application ───────────────────────────────
APP_PORT=8000
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO
RETRIEVER_K=5

# ── Ingestion ─────────────────────────────────
# Local path or remote URL used by the ingest pipeline
DATA_SOURCE_PATH=./data/cities.jsonl
